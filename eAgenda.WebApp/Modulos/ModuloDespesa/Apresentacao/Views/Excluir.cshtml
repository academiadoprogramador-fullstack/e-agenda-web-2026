@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Despesa";
}

@model ExcluirDespesaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden">

    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Deseja realmente excluir esta despesa?
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">ID</dt>
        <dd class="col-sm-8 text-break">@Model.Id</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Descrição</dt>
        <dd class="col-sm-8">@Model.Descricao</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Data</dt>
        <dd class="col-sm-8">@Model.DataOcorrencia.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Valor</dt>
        <dd class="col-sm-8">@Model.Valor.ToString("C")</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Pagamento</dt>
        <dd class="col-sm-8">@(Model.FormaPagamento.ToString() switch { "AVista" => "À Vista", "Credito" => "Crédito", "Debito" => "Débito", _ => Model.FormaPagamento.ToString() })</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Categorias</dt>
        <dd class="col-sm-8">@string.Join(", ", Model.Categorias.Select(c => c.Titulo))</dd>
    </dl>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>
