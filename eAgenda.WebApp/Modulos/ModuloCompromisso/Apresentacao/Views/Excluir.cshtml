@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Compromisso";
}

@model ExcluirCompromissoViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden">

    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Deseja realmente excluir este compromisso?
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">ID</dt>
        <dd class="col-sm-8 text-break">@Model.Id</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Assunto</dt>
        <dd class="col-sm-8">@Model.Assunto</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Data</dt>
        <dd class="col-sm-8">@Model.DataOcorrencia.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Horário</dt>
        <dd class="col-sm-8">@Model.HoraInicio.ToString(@"hh\:mm") - @Model.HoraTermino.ToString(@"hh\:mm")</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Tipo</dt>
        <dd class="col-sm-8">@Model.Tipo</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Contato</dt>
        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.ContatoNome) ? "Não informado" : Model.ContatoNome)</dd>
    </dl>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>
