@model ListarTarefasViewModel;

<div class="col">
    <div class="card h-100">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <h5 class="card-title mb-0">@Model.Titulo</h5>
                <span class="badge text-bg-primary rounded-pill">@Model.Prioridade</span>
            </div>

            <dl class="row g-2 mb-4">
                <dt class="col-5 text-secondary fw-semibold">Criação</dt>
                <dd class="col-7 mb-0">@Model.DataCriacao.ToString("dd/MM/yyyy")</dd>

                <dt class="col-5 text-secondary fw-semibold">Conclusão</dt>
                <dd class="col-7 mb-0">@(Model.DataConclusao?.ToString("dd/MM/yyyy") ?? "Pendente")</dd>

                <dt class="col-5 text-secondary fw-semibold">Status</dt>
                <dd class="col-7 mb-0">@(Model.Concluida ? "Concluída" : "Pendente")</dd>

                <dt class="col-5 text-secondary fw-semibold">Itens</dt>
                <dd class="col-7 mb-0">@Model.Itens.Count</dd>
            </dl>

            <div class="progress mb-3" role="progressbar" aria-label="Percentual concluido" aria-valuenow="@Model.PercentualConcluido" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar" style="width: @Model.PercentualConcluido%">@Model.PercentualConcluido%</div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                @if (Model.Itens.Count == 0)
                {
                    <form asp-action="AlterarConclusao" method="post">
                        <input name="TarefaId" type="hidden" value="@Model.Id">
                        <input name="Concluida" type="hidden" value="@(Model.Concluida ? "false" : "true")">
                        <button class="btn btn-outline-primary btn-sm rounded-pill px-3" type="submit">@(Model.Concluida ? "Reabrir" : "Concluir")</button>
                    </form>
                }

                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="GerenciarItens" asp-route-id="@Model.Id">Itens</a>
                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar" asp-route-id="@Model.Id">Editar</a>
                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir" asp-route-id="@Model.Id">Excluir</a>
            </div>
        </div>
    </div>
</div>
